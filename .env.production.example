APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=ChangeMeNow
APP_AUTH_DISPLAY_NAME=Alpha Operator
APP_PILOT_USERNAME=pilot
APP_PILOT_PASSWORD=ChangePilotNow
APP_PILOT_DISPLAY_NAME=Alpha Pilot
APP_AUTH_SECRET=replace-with-a-long-random-secret
APP_AUTH_TOKEN_TTL_HOURS=12
