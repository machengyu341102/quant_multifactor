# === 机密配置模板 (入 Git, 值为空/占位符) ===
# 复制为 .env 后填入真实值

# Server酱推送 (https://sct.ftqq.com/)
SERVERCHAN_SENDKEY=

# 企业微信应用消息
WECOM_CORP_ID=
WECOM_AGENT_ID=0
WECOM_SECRET=

# 企业微信群机器人 (备选, 留空则不用)
WECOM_BOT_KEY=

# Tushare Pro 金融数据 (https://tushare.pro/)
TUSHARE_TOKEN=

# 天勤量化 (期货 simnow/live 模式)
TQSDK_USER=
TQSDK_PASSWORD=

# 同花顺 Web 交易网关 (留空=demo模式)
THS_USERNAME=
THS_PASSWORD=
THS_COOKIE=

# 期货实盘 (live 模式)
FUTURES_BROKER_ID=
FUTURES_ACCOUNT=
FUTURES_PASSWORD=

# LLM API Keys
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# App 登录账号
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=
APP_AUTH_DISPLAY_NAME=Alpha Operator
APP_PILOT_USERNAME=pilot
APP_PILOT_PASSWORD=
APP_PILOT_DISPLAY_NAME=Alpha Pilot
